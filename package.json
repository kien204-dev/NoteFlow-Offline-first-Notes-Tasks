{
  "name": "noteflow",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "concurrently \"npm:dev:server\" \"npm:dev\"",
    "build": "npm run build --workspace=client",
    "preview": "npm run preview --workspace=client",
    "server:migrate": "npm run migrate --workspace=server",
    "test": "npm run test:run --workspace=client; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm test --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
